# Recipe Lens - Environment Configuration
# Copy this file to .env and fill in your API keys

# Groq API Key (required - for all AI inference)
GROQ_API_KEY=your_groq_api_key_here

# HuggingFace Token (optional - for fallback vision model)
HF_TOKEN=your_hf_token_here

# Gemini API Key (for superior vision detection)
GEMINI_API_KEY=your_gemini_api_key_here

# Flask settings
FLASK_DEBUG=False
FLASK_PORT=5000
